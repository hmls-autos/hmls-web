{
  "name": "@hmls/gateway",
  "version": "0.1.0",
  "exports": "./src/index.ts",
  "compilerOptions": {
    "skipLibCheck": true
  },
  "imports": {
    "@react-pdf/renderer": "npm:@react-pdf/renderer@^4.3.2",
    "react": "npm:react@^19.2.4",
    "@supabase/supabase-js": "npm:@supabase/supabase-js@^2.99.1"
  },
  "deploy": {
    "org": "spinsirr",
    "app": "hmls-api"
  },
  "tasks": {
    "dev": "deno run --env=../../.env.local --allow-net --allow-env --allow-read --allow-write --allow-run --allow-sys --allow-ffi --watch src/index.ts",
    "start": "deno run --env=../../.env.local --allow-net --allow-env --allow-read --allow-write --allow-run --allow-sys --allow-ffi src/index.ts",
    "test": "deno test --allow-env --allow-read --allow-net --allow-sys --allow-ffi src/"
  }
}
